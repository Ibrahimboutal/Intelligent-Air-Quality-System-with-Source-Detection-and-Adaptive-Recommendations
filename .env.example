# --- Raspberry Pi (Edge) Configuration ---
PI_IP=192.168.1.100
PI_USER=pi
PI_PASS=your_password_here
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=9600

# --- MATLAB (Intelligence Hub) Configuration ---
# The IP of the machine running the MATLAB Intelligence Dashboard
MATLAB_IP=192.168.1.10
# Standard port for the Intelligence TCP Server (matches CI/CD)
MATLAB_PORT=5056

# --- Third-Party Integrations ---
# For automated coverage reporting
CODECOV_TOKEN=your_token_here

# --- Security Configuration ---
# Set to true only if you have configured SSL certificates on both ends
USE_SSL=false
SSL_CERT_PATH=
